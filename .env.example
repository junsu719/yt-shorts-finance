# 複製此檔案為 config/.env 並填入實際金鑰
# cp .env.example config/.env

# Gemini API（腳本生成 + Imagen 3 圖像生成）
# 取得：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Kling AI API（AI 影片生成，測試中）
# 取得：https://klingai.com/dev
KLING_API_KEY=
KLING_API_SECRET=

# Pexels API（背景影片素材）
# 取得：https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API（背景影片素材）
# 取得：https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Vecteezy API（背景影片素材）
# 取得：https://www.vecteezy.com/developers
VECTEEZY_API_KEY=

# YouTube Data API v3（影片上傳）
# 取得：https://console.cloud.google.com/
# 注意：需搭配 config/client_secret.json（OAuth2 憑證）
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
